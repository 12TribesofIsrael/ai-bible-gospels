# ── General AI Movie Pipeline ──────────────────────────────────────────────────

# OpenAI — script parsing (GPT-4o) and narration (TTS)
OPENAI_API_KEY=sk-...

# fal.ai — image generation (FLUX) and video generation (Kling)
# Get your key at https://fal.ai/dashboard/keys
FAL_KEY=your-fal-api-key

# Where generated movies and intermediate files are saved
OUTPUT_DIR=output


# ── Biblical Cinematic Workflow (n8n) ──────────────────────────────────────────

# Perplexity AI — generates 20 cinematic scenes from scripture text
PERPLEXITY_API_KEY=pplx-...

# ElevenLabs — voice synthesis for narration
ELEVENLABS_API_KEY=your-elevenlabs-api-key

# JSON2Video — renders the 20-scene video with Ken Burns effects
JSON2VIDEO_API_KEY=your-json2video-api-key

# n8n webhook URL — used by the optional React UI to trigger the workflow
N8N_WEBHOOK_URL=https://your-n8n-instance.com/webhook/your-webhook-id


# ── Custom Script Pipeline ────────────────────────────────────────────────────

# Anthropic — Claude AI for scene generation (custom-script workflow)
ANTHROPIC_API_KEY=sk-ant-...
