# Environment
.env
modal-secrets.env

# Claude Code local settings
.claude/

# Generated output
output/
!output/.gitkeep

# Runtime state — rewritten by the app on every render, never source of truth
workflows/biblical-cinematic/server/pipeline_state.json
workflows/biblical-cinematic/server/usage_log.json
workflows/custom-script/custom_render_history.json

# Python
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/
*.egg-info/
dist/
build/
.pytest_cache/

# YouTube OAuth credentials (never commit these)
workflows/biblical-cinematic/scripts/client_secrets.json
workflows/biblical-cinematic/scripts/.youtube_token.json

# Video/audio assets (large files — keep locally, not in git)
*.mp4
*.mov
*.mkv
*.mp3
*.wav

# Exception: landing-page web assets (compressed, ~5 MB total) ship with the repo
# so a fresh clone can `modal deploy` without re-running ffmpeg.
# Raw source masters in landingpage/ (P.mp4, 1.mp4, 2.mp4, z.mp4) stay ignored.
!landingpage/web/*.mp4

# OS
.DS_Store
Thumbs.db

# Scratch files from chapter renders / recoveries (root-level only)
/ch*_chunks.json
/ch*_processed.json
/ch*_recovered_urls.json
/retry_payload.json
/retry_part*.json
/macc*.txt
/package-lock.json
/backup_*_state_*.json

# Custom-script recovery scratch (user-specific inputs + one-shot outputs)
workflows/custom-script/recovery_scenes.json
workflows/custom-script/recovered_payload.json

# Cloudflare Worker — wrangler local cache (regenerated by every deploy)
ops/cloudflare-proxy/.wrangler/
